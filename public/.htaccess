# =============================================================================
# ALAYA INSIDER — Hostinger .htaccess
# =============================================================================
# This file is copied to dist/ during build and should be uploaded to
# your Hostinger public_html/ directory alongside index.html.
#
# Note: The app uses HashRouter (#/routes), so no SPA rewrite rules are
# needed for client-side routing to work.
# =============================================================================

# ---- Security Headers ----
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "no-referrer"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https://images.pexels.com https://*.pexels.com; connect-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com https://alaya-insider-api-production.up.railway.app; frame-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"

    # Cache static assets aggressively (1 year, immutable)
    <FilesMatch "\.(js|css|svg|png|jpg|jpeg|ico|woff2?|webp)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # HTML: validate on each visit (no cache)
    <FilesMatch "\.html?$">
        Header set Cache-Control "public, max-age=0, must-revalidate"
        Header set CDN-Cache-Control "no-cache"
        Header set Cloudflare-CDN-Cache-Control "no-cache"
    </FilesMatch>

    # JSON, text files: short cache
    <FilesMatch "\.(json|txt|xml)$">
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>
</IfModule>

# ---- Compression ----
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml image/x-icon
</IfModule>

# ---- MIME Types ----
<IfModule mod_mime.c>
    AddType image/svg+xml .svg
    AddType application/json .json
    AddType application/manifest+json .webmanifest
</IfModule>

# ---- Deny access to hidden files ----
<FilesMatch "^\.">
    Deny from all
</FilesMatch>

# ---- Directory index ----
DirectoryIndex index.html

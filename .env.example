# ═══════════════════════════════════════════════════════════════════════
# ALAYA INSIDER — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# These vars are available at build time via import.meta.env.VITE_*
# For runtime config, set window.__ALAYA_CONFIG__ in index.html.
#
# Required:
#   VITE_API_URL — Your backend REST API base URL
#
# Optional:
#   VITE_API_TOKEN    — JWT bearer token for authentication
#   VITE_API_KEY      — API key (alternative to bearer token)
#   VITE_API_TIMEOUT  — Request timeout in ms (default: 15000)
#   VITE_API_DEBUG    — Set "true" for verbose API logging
# ═══════════════════════════════════════════════════════════════════════

# ── Backend API ─────────────────────────────────────────────────────
# The base URL of the ALAYA INSIDER REST API.
# Examples:
#   VITE_API_URL=http://localhost:3000/api/v1
#   VITE_API_URL=https://api.alayainsider.com/v1
#   VITE_API_URL=https://staging-api.alayainsider.com/v1
#
# When empty, the app runs in local-only mode (no backend sync).
VITE_API_URL=

# ── Authentication ──────────────────────────────────────────────────
# Either provide a JWT bearer token or an API key.
#   VITE_API_TOKEN=<your-jwt-token>
#   VITE_API_KEY=<your-api-key>
VITE_API_TOKEN=
VITE_API_KEY=

# ── Request Configuration ───────────────────────────────────────────
VITE_API_TIMEOUT=15000
VITE_API_MAX_RETRIES=3
VITE_API_DEBUG=false

# ── Fallback Behaviour ──────────────────────────────────────────────
# When true (default), the app falls back to localStorage persistence
# if the backend is unreachable. Set to "false" to require the backend.
VITE_LOCALSTORAGE_FALLBACK=true
